# ── Database (Railway injects DATABASE_URL automatically when PostgreSQL plugin is added) ──
DATABASE_URL=${{Postgres.DATABASE_URL}}
POSTGRES_USER=${{Postgres.PGUSER}}
POSTGRES_PASSWORD=${{Postgres.PGPASSWORD}}
POSTGRES_DB=${{Postgres.PGDATABASE}}

# ── Redis (Railway injects REDIS_URL automatically when Redis plugin is added) ──
REDIS_URL=${{Redis.REDIS_URL}}

# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=<generate-a-secure-random-32-byte-hex-string>
ENVIRONMENT=production

# ── Spending caps (USD) — adjust for your budget ─────────────────────────────
DAILY_HARD_CAP_ADS=100
DAILY_HARD_CAP_APIS=50
WEEKLY_SOFT_CAP_TOTAL=500
MONTHLY_HARD_CEILING=2000

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
LLM_MODEL_SMART=claude-sonnet-4-6
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# ── Discord / King Solomon ────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=<your-discord-bot-token>
DISCORD_APPROVALS_CHANNEL_ID=<channel-id>
DISCORD_UPDATES_CHANNEL_ID=<channel-id>
DISCORD_ALERTS_CHANNEL_ID=<channel-id>
# Set to your Railway backend public URL after first deploy
DISCORD_BACKEND_URL=https://<your-backend-service>.up.railway.app

# ── PORT (Railway sets this automatically — do NOT set manually) ──────────────
# PORT=<injected-by-railway>
