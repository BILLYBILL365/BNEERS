# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/projectmillion
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=projectmillion

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
ENVIRONMENT=development

# ── Spending caps (USD) ───────────────────────────────────────────────────────
DAILY_HARD_CAP_ADS=100
DAILY_HARD_CAP_APIS=50
WEEKLY_SOFT_CAP_TOTAL=500
MONTHLY_HARD_CEILING=2000

# ── Anthropic (leave empty to run agents in mock/no-llm mode) ─────────────────
ANTHROPIC_API_KEY=
LLM_MODEL_SMART=claude-sonnet-4-6
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# ── Discord / King Solomon bot (leave empty to disable) ──────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APPROVALS_CHANNEL_ID=0
DISCORD_UPDATES_CHANNEL_ID=0
DISCORD_ALERTS_CHANNEL_ID=0
DISCORD_BACKEND_URL=http://localhost:8000
